{
  // App daemon entry points run through scripts/run-dev.zsh so macOS TCC
  // permissions use the signed .app bundle id, not SwiftPM's ad-hoc debug id.
  // VS Code draws a divider between different `presentation.group` values.
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node-terminal",
      "request": "launch",
      "name": "🚀 Run Dev App Bundle",
      "command": "./scripts/run-dev.zsh",
      "cwd": "${workspaceFolder:copy-translator}",
      "presentation": { "group": "1_app", "order": 1 }
    },
    {
      "type": "node-terminal",
      "request": "launch",
      "name": "⚙️ Settings Window App Bundle",
      "command": "./scripts/run-dev.zsh --show-settings",
      "cwd": "${workspaceFolder:copy-translator}",
      "presentation": { "group": "1_app", "order": 2 }
    },
    {
      "type": "swift",
      "request": "launch",
      "name": "Run Release",
      "target": "CopyTranslator",
      "configuration": "release",
      "args": [],
      "cwd": "${workspaceFolder:copy-translator}",
      "preLaunchTask": "swift: Build Release CopyTranslator",
      "presentation": { "group": "2_release", "order": 1 }
    },
    {
      "type": "swift",
      "request": "launch",
      "name": "Translate Text Once (Debug)",
      "target": "CopyTranslator",
      "configuration": "debug",
      // One-shot pipeline test: prints the translation and exits (no menu bar daemon).
      "args": ["--translate-text-once", "${input:textToTranslate}"],
      "cwd": "${workspaceFolder:copy-translator}",
      "preLaunchTask": "swift: Build Debug CopyTranslator",
      "presentation": { "group": "3_oneshot", "order": 1 }
    },
    {
      "type": "swift",
      "request": "launch",
      "name": "Screenshot Translate Once (Debug)",
      "target": "CopyTranslator",
      "configuration": "debug",
      // Captures the main display, translates it via the OpenRouter vision model, then exits.
      "args": ["--screenshot-once"],
      "cwd": "${workspaceFolder:copy-translator}",
      "preLaunchTask": "swift: Build Debug CopyTranslator",
      "presentation": { "group": "3_oneshot", "order": 2 }
    }
  ],
  "inputs": [
    {
      "id": "textToTranslate",
      "type": "promptString",
      "description": "Text to translate once",
      "default": "Hello, world"
    }
  ]
}
