{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CopyTranslator",
  "version": "0.1.0",
  "identifier": "as.kargn.copy-translator",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist-web"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "CopyTranslator Settings",
        "width": 680,
        "height": 575,
        "minWidth": 640,
        "minHeight": 540,
        "resizable": true,
        "decorations": true,
        "center": true,
        "transparent": true,
        "windowEffects": {
          "effects": ["sidebar"],
          "state": "active"
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
