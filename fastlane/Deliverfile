# fastlane deliver configuration for the Mac App Store listing.
# Auth comes from --api_key_path at invocation time (release-mas.yml);
# nothing credential-shaped belongs in this file.
app_identifier "as.kargn.cctrans"
platform "osx"

# The store listing is source-controlled: metadata/ + screenshots/ are the
# single source of truth, pushed with --force (skips the HTML preview).
metadata_path "./fastlane/metadata"
screenshots_path "./fastlane/screenshots"

# Binary uploads are altool's job in release-mas.yml; deliver only manages
# the listing. Submission stays manual until the listing stabilizes.
skip_binary_upload true
submit_for_review false
automatic_release false

# Precheck aborts with "cannot check In-app purchases with the App Store
# Connect API Key" even though this app has no IAP at all, and it runs AFTER
# the metadata upload — so it only turns a successful run into exit 1.
run_precheck_before_submit false

# Pricing is NOT managed here: deliver's price_tier path uses legacy ASC
# endpoints that Apple removed (availableInNewTerritories). The free price
# schedule was set once through the App Store Connect API directly.

# App Review contact. The ASC API rejects review details without a phone
# number, and a personal number must not live in this public repo, so it
# comes from the environment (CCTRANS_REVIEW_PHONE secret in CI, exported
# locally for manual runs). Other contact fields are public anyway.
review_phone = ENV["CCTRANS_REVIEW_PHONE"].to_s
raise "Set CCTRANS_REVIEW_PHONE (e.g. +82 10 1234 5678) for the App Review contact" if review_phone.strip.empty?
app_review_information(
  first_name: "Sangrak",
  last_name: "Choi",
  phone_number: review_phone,
  email_address: "kars@kargn.as",
  # Deliverfile is eval'd, so __dir__ points at the CWD (repo root), not this
  # file; keep the path repo-root-relative like metadata_path above.
  notes: File.read("./fastlane/metadata/review_information/notes.txt")
)
